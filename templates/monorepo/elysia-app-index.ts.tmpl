---
variables:
  app_name: "Name of the ElysiaJS app"
  port: "Port number (default: 3000)"
---

import { Elysia } from 'elysia'

const app = new Elysia()
  .get('/', () => 'Hello from {{app_name}}')
  .get('/health', () => ({ status: 'ok' }))
  .listen({{port}})

console.log(`{{app_name}} running at ${app.server?.hostname}:${app.server?.port}`)
